{
  "entities": {
    "Cliente": {
      "title": "Cliente",
      "description": "Produtor rural ou empresa cliente da oficina.",
      "type": "object",
      "properties": {
        "nome": { "type": "string", "description": "Nome completo ou razão social" },
        "email": { "type": "string", "format": "email", "description": "Endereço de e-mail" },
        "telefone": { "type": "string", "description": "Número de telefone" },
        "cpf_cnpj": { "type": "string", "description": "Documento de identificação" },
        "inscricao_estadual": { "type": "string", "description": "Inscrição Estadual" },
        "inscricao_municipal": { "type": "string", "description": "Inscrição Municipal" },
        "logradouro": { "type": "string", "description": "Logradouro (Rua, Avenida, etc.)" },
        "numero": { "type": "string", "description": "Número" },
        "complemento": { "type": "string", "description": "Complemento" },
        "bairro": { "type": "string", "description": "Bairro" },
        "cep": { "type": "string", "description": "CEP" },
        "cidade": { "type": "string", "description": "Cidade" },
        "uf": { "type": "string", "description": "UF" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Data de cadastro" },
        "uid": { "type": "string", "description": "ID do usuário que cadastrou" }
      },
      "required": ["nome", "cpf_cnpj", "logradouro", "numero", "bairro", "cep", "cidade", "uf", "uid"]
    },
    "Veiculo": {
      "title": "Veículo/Equipamento",
      "description": "Máquina agrícola cadastrada no sistema.",
      "type": "object",
      "properties": {
        "clienteId": { "type": "string", "description": "ID do cliente proprietário" },
        "modelo": { "type": "string", "description": "Modelo da máquina" },
        "marca": { "type": "string", "description": "Marca do fabricante" },
        "ano": { "type": "integer", "description": "Ano de fabricação" },
        "placa_serie": { "type": "string", "description": "Número de série ou placa" },
        "tipo": { "type": "string", "enum": ["Trator", "Colheitadeira", "Pulverizador", "Outros"], "description": "Tipo de equipamento" },
        "uid": { "type": "string", "description": "ID do usuário que cadastrou" }
      },
      "required": ["clienteId", "modelo", "marca", "ano", "placa_serie", "tipo", "uid"]
    },
    "OrdemServico": {
      "title": "Ordem de Serviço",
      "description": "Registro de serviço realizado em uma máquina.",
      "type": "object",
      "properties": {
        "numero": { "type": "string", "description": "Número identificador da OS" },
        "clienteId": { "type": "string", "description": "ID do cliente" },
        "veiculoId": { "type": "string", "description": "ID do veículo" },
        "status": { "type": "string", "enum": ["Aberta", "Em Andamento", "Aguardando Peças", "Finalizada", "Cancelada"], "description": "Status atual da OS" },
        "tecnicoResponsavel": { "type": "string", "description": "Nome do técnico responsável pelo serviço" },
        "descricao": { "type": "string", "description": "Descrição detalhada do serviço" },
        "fotos": { "type": "array", "items": { "type": "string" }, "description": "Lista de URLs ou base64 das fotos do serviço" },
        "quilometragemInicial": { "type": "string", "description": "Quilometragem ou horas iniciais" },
        "quilometragemFinal": { "type": "string", "description": "Quilometragem ou horas finais" },
        "observacoes": { "type": "string", "description": "Observações adicionais" },
        "valorTotal": { "type": "number", "description": "Valor total do serviço" },
        "dataAbertura": { "type": "string", "format": "date-time", "description": "Data de abertura" },
        "dataFinalizacao": { "type": "string", "format": "date-time", "description": "Data de finalização" },
        "dataTermino": { "type": "string", "format": "date-time", "description": "Data de término real" },
        "uid": { "type": "string", "description": "ID do usuário que cadastrou" }
      },
      "required": ["numero", "clienteId", "veiculoId", "status", "descricao", "valorTotal", "dataAbertura", "uid"]
    },
    "Orcamento": {
      "title": "Orçamento",
      "description": "Proposta de serviço para aprovação do cliente.",
      "type": "object",
      "properties": {
        "numero": { "type": "string", "description": "Número identificador do orçamento" },
        "clienteId": { "type": "string", "description": "ID do cliente" },
        "veiculoId": { "type": "string", "description": "ID do veículo" },
        "status": { "type": "string", "enum": ["Pendente", "Aprovado", "Recusado", "Vencido"], "description": "Status do orçamento" },
        "tecnicoResponsavel": { "type": "string", "description": "Técnico que elaborou o orçamento" },
        "descricao": { "type": "string", "description": "Descrição dos serviços orçados" },
        "fotos": { "type": "array", "items": { "type": "string" }, "description": "Fotos do estado atual" },
        "quilometragemInicial": { "type": "string", "description": "KM/Horas no momento do orçamento" },
        "quilometragemFinal": { "type": "string", "description": "KM/Horas previsto" },
        "observacoes": { "type": "string", "description": "Observações gerais" },
        "valorTotal": { "type": "number", "description": "Valor total orçado" },
        "validade": { "type": "string", "format": "date", "description": "Data de validade da proposta" },
        "uid": { "type": "string", "description": "ID do usuário que cadastrou" }
      },
      "required": ["numero", "clienteId", "veiculoId", "status", "descricao", "valorTotal", "validade", "uid"]
    },
    "Configuracao": {
      "title": "Configuração",
      "description": "Configurações globais da oficina.",
      "type": "object",
      "properties": {
        "nomeOficina": { "type": "string", "description": "Nome da oficina" },
        "cnpj": { "type": "string", "description": "CNPJ da oficina" },
        "inscricaoMunicipal": { "type": "string", "description": "Inscrição Municipal" },
        "inscricaoEstadual": { "type": "string", "description": "Inscrição Estadual" },
        "endereco": { "type": "string", "description": "Logradouro e número" },
        "complemento": { "type": "string", "description": "Complemento" },
        "cidade": { "type": "string", "description": "Cidade" },
        "uf": { "type": "string", "description": "UF" },
        "telefone": { "type": "string", "description": "Telefone de contato" },
        "email": { "type": "string", "description": "E-mail de contato" },
        "logo": { "type": "string", "description": "Logo em Base64" },
        "uid": { "type": "string", "description": "ID do usuário (dono)" }
      },
      "required": ["nomeOficina", "uid"]
    },
    "Agendamento": {
      "title": "Agendamento",
      "description": "Compromissos e visitas técnicas agendadas.",
      "type": "object",
      "properties": {
        "clienteId": { "type": "string", "description": "ID do cliente" },
        "data": { "type": "string", "format": "date-time", "description": "Data e hora do agendamento" },
        "descricao": { "type": "string", "description": "Descrição do serviço" },
        "local": { "type": "string", "description": "Local ou fazenda" },
        "uid": { "type": "string", "description": "ID do usuário (dono)" }
      },
      "required": ["clienteId", "data", "descricao", "uid"]
    },
    "Peca": {
      "title": "Peça",
      "description": "Peça ou produto em estoque.",
      "type": "object",
      "properties": {
        "codigo": { "type": "string", "description": "Código da peça ou SKU" },
        "descricao": { "type": "string", "description": "Descrição da peça" },
        "marca": { "type": "string", "description": "Marca do fabricante" },
        "precoCusto": { "type": "number", "description": "Preço de custo" },
        "precoVenda": { "type": "number", "description": "Preço de venda" },
        "estoque": { "type": "number", "description": "Quantidade em estoque" },
        "estoqueMinimo": { "type": "number", "description": "Estoque mínimo para alerta" },
        "unidade": { "type": "string", "description": "Unidade de medida (UN, KG, etc)" },
        "uid": { "type": "string", "description": "ID do usuário que cadastrou" }
      },
      "required": ["codigo", "descricao", "precoVenda", "estoque", "unidade", "uid"]
    }
  },
  "firestore": {
    "/clientes/{clienteId}": {
      "schema": "Cliente",
      "description": "Coleção de clientes da oficina."
    },
    "/veiculos/{veiculoId}": {
      "schema": "Veiculo",
      "description": "Coleção de máquinas e equipamentos."
    },
    "/ordens_servico/{osId}": {
      "schema": "OrdemServico",
      "description": "Coleção de ordens de serviço."
    },
    "/orcamentos/{orcamentoId}": {
      "schema": "Orcamento",
      "description": "Coleção de orçamentos."
    },
    "/configuracoes/{configId}": {
      "schema": "Configuracao",
      "description": "Configurações da oficina."
    },
    "/agendamentos/{agendamentoId}": {
      "schema": "Agendamento",
      "description": "Coleção de agendamentos."
    },
    "/pecas/{pecaId}": {
      "schema": "Peca",
      "description": "Coleção de peças e produtos."
    }
  }
}
